# PostgreSQL (required for app and for running/creating migrations)
DATABASE_URL=postgresql://user:password@localhost:5432/streetrack

# Dedicated Postgres DB for pytest (required for tests). Same migration files apply to both DBs.
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/streetrack_test

# Auth0 JWT (optional for local dev)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.streetrack.example
AUTH0_ISSUER=https://your-tenant.auth0.com/

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
